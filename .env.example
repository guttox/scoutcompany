# =====================================================
# Scout — template das variáveis de ambiente
# Copie pra .env e preencha. NUNCA commitar .env real.
# Em produção (Railway), configure essas vars no painel
# Settings → Variables, não use .env.
# =====================================================

# ----- Google Places API -----
# https://console.cloud.google.com/google/maps-apis
# Custo: ~US$ 0.017/text-search; ~US$ 0.005/place details.
GOOGLE_PLACES_KEY=

# ----- Anthropic (Claude) API -----
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ----- Telegram Bot -----
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ----- WhatsApp comercial Scout -----
WHATSAPP_SCOUT=

# ----- Evolution API (WhatsApp) -----
# Em prod no Railway, aponta pro serviço Evolution rodando lá.
EVOLUTION_URL=http://localhost:8080
EVOLUTION_APIKEY=
EVOLUTION_INSTANCE=scout-wa

# ----- Modo de envio -----
# DRY  → simula, registra em log, NÃO envia WhatsApp real
# LIVE → envia mensagens reais
DISPATCH_MODE=DRY

# ----- Comportamento -----
USE_MOCK=0
SCORE_MIN=6
MAX_PROSPECTS=50

# Digest de prospects no Telegram (0=off recomendado em LIVE)
TELEGRAM_DIGEST=0

# Porta do webhook server (Railway usa $PORT — código respeita)
WEBHOOK_PORT=5005

# Assinatura usada nas mensagens
ASSINATURA_NOME=Augusto Barbosa
ASSINATURA_TELEFONE=+55 11 94067-0464

# Busca: localização e rodízio
LOCALIZACAO_PADRAO=Guarulhos, SP
RAIO_BUSCA_KM=50
CIDADES_RODIZIO=São Paulo,Guarulhos,Campinas,Santo André,São Bernardo do Campo,Osasco,Sorocaba,Ribeirão Preto,São José dos Campos,Santos,Mauá,Mogi das Cruzes,Diadema,Carapicuíba,Itaquaquecetuba
CIDADES_POR_RODADA=3
