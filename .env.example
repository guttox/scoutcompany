# =====================================================
# Scout — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# =====================================================

# ----- Google Places API -----
# Como obter: https://console.cloud.google.com/google/maps-apis
# Habilite "Places API (New)" e gere uma API key.
# Custo: ~US$ 0.017 por busca text-search; ~US$ 0.005 por place details.
# Defina cota diária no console pra não estourar (ex: $5/dia).
GOOGLE_PLACES_KEY=

# ----- Anthropic (Claude) API -----
# Como obter: https://console.anthropic.com/settings/keys
# Custo aprox: Sonnet 4.6 ≈ $0.003/mensagem gerada.
# Defina cota mensal pra controle.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ----- Telegram Bot -----
# Bot dedicado do Scout (criado no @BotFather, separado da Amantius).
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ----- Comportamento -----
# Se uma das keys (Google ou Anthropic) faltar, o sistema cai para mock/template.
# Force mock mode: USE_MOCK=1
USE_MOCK=0

# Score mínimo pra considerar prospect QUALIFICADO (default: 6)
SCORE_MIN=6

# Máximo de prospects a buscar por execução (custo control)
MAX_PROSPECTS=50

# Assinatura usada nas mensagens (Email + WhatsApp)
ASSINATURA_NOME=Augusto Barbosa
ASSINATURA_TELEFONE=+55 11 94067-0464

# Localização padrão pra busca
LOCALIZACAO_PADRAO=Guarulhos, SP
RAIO_BUSCA_KM=15
